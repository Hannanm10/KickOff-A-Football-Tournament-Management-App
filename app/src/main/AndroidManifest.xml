            android:name=".activities.MatchListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AddTeamActivity"
            android:exported="false" />
        <activity
            android:name=".activities.TeamListActivity"
            android:exported="false" />
        <activity
            android:name=".activities.TournamentDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AddTournamentActivity"
            android:exported="false" />
